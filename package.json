{
  "name": "beast-cli",
  "version": "0.1.0",
  "description": "The ultimate AI coding agent — born from the best of Claude Code, Gemini CLI, and OpenCode",
  "main": "src/index.ts",
  "bin": {
    "beast": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "lint": "biome check src/"
  },
  "keywords": ["ai", "cli", "coding-agent", "llm", "terminal"],
  "license": "MIT",
  "dependencies": {
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "commander": "^12.0.0",
    "zod": "^3.23.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0",
    "@biomejs/biome": "^1.8.0"
  }
}
