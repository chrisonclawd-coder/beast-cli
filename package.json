{
  "name": "beast-cli",
  "version": "0.2.0",
  "description": "The ultimate AI coding agent — born from the best of Claude Code, Gemini CLI, and OpenCode",
  "main": "dist/app.js",
  "bin": {
    "beast": "bin/beast.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "npx tsx src/cli/index.ts chat",
