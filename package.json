{
  "name": "beast-cli",
  "version": "0.2.0",
  "description": "🦁 The ultimate AI coding agent",
  "main": "dist/index.js",
  "bin": {
    "beast": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "npx tsx src/cli/index.ts chat",
    "dev:bun": "bun run src/cli/index.ts chat",
    "test": "echo 'no tests yet'",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "preferGlobal": true,
  "keywords": [
    "ai",
    "cli",
    "coding-agent",
    "llm",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "ink": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "react": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  }
}
